  {
   "cell_type": "markdown",
   "metadata": {
    "id": "download_results"
   },
   "source": [
    "## Step 7: Download the MuseScore File\n",
    "\n",
    "Download your transcribed music file to use in MuseScore!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "download_output"
   },
   "outputs": [],
   "source": [
    "from google.colab import files\n",
    "import os\n",
    "import glob\n",
    "\n",
    "output_dir = '/content/music_transcription/output'\n",
    "\n",
    "if os.path.exists(output_dir):\n",
    "    musescore_files = glob.glob(os.path.join(output_dir, '*.mscx')) + \\\n",
    "                     glob.glob(os.path.join(output_dir, '*.mscz')) + \\\n",
    "                     glob.glob(os.path.join(output_dir, '*.xml'))\n",
    "    \n",
    "    if musescore_files:\n",
    "        print(\"📥 Ready to download!\\n\")\n",
    "        for file in musescore_files:\n",
    "            filename = os.path.basename(file)\n",
    "            print(f\"⬇️  Downloading: {filename}\")\n",
    "            files.download(file)\n",
    "        print(\"\\n✅ Download complete!\")\n",
    "    else:\n",
    "        print(\"⚠️ No MuseScore files found to download.\")\n",
    "        print(\"Run the transcription cell above first.\")\nelse:\n",
    "    print(\"⚠️ Output directory not found.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "advanced_options"
   },
   "source": [
    "## Advanced Options\n",
    "\n",
    "### Process Multiple PDFs (Batch Processing)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "batch_processing"
   },
   "outputs": [],
   "source": [
    "from google.colab import files\n",
    "import os\n",
    "import time\n",
    "\n",
    "print(\"📤 Upload multiple PDF files for batch processing...\\n\")\n",
    "uploaded = files.upload()\n",
    "\n",
    "if uploaded:\n",
    "    output_dir = '/content/music_transcription/batch_output'\n",
    "    os.makedirs(output_dir, exist_ok=True)\n",
    "    \n",
    "    pdf_files = [f for f in uploaded.keys() if f.endswith('.pdf')]\n",
    "    \n",
    "    print(f\"\\n📊 Batch Processing {len(pdf_files)} files...\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    for idx, pdf_file in enumerate(pdf_files, 1):\n",
    "        pdf_path = f'/content/music_transcription/{pdf_file}'\n",
    "        title = pdf_file.replace('.pdf', '').replace('_', ' ').title()\n",
    "        \n",
    "        print(f\"\\n[{idx}/{len(pdf_files)}] Processing: {pdf_file}\")\n",
    "        \n",
    "        start_time = time.time()\n",
    "        result = transcribe_pdf_to_musescore(\n",
    "            pdf_path=pdf_path,\n",
    "            output_dir=output_dir,\n",
    "            title=title\n",
    "        )\n",
    "        elapsed = time.time() - start_time\n",
    "        \n",
    "        if result['success']:\n",
    "            print(f\"  ✅ Success - {result['notes_detected']} notes, {elapsed:.1f}s\")\n",
    "            results.append({\n",
    "                'file': pdf_file,\n",
    "                'status': 'success',\n",
    "                'notes': result['notes_detected'],\n",
    "                'pages': result['pages_processed'],\n",
    "                'time': elapsed\n",
    "            })\n",
    "        else:\n",
    "            print(f\"  ❌ Failed - {result['error']}\")\n",
    "            results.append({\n",
    "                'file': pdf_file,\n",
    "                'status': 'failed',\n",
    "                'error': result['error']\n",
    "            })\n",
    "    \n",
    "    # Summary\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"\\n📈 BATCH PROCESSING SUMMARY:\")\n",
    "    successful = sum(1 for r in results if r['status'] == 'success')\n",
    "    failed = sum(1 for r in results if r['status'] == 'failed')\n",
    "    \n",
    "    print(f\"  ✅ Successful: {successful}/{len(pdf_files)}\")\n",
    "    print(f\"  ❌ Failed: {failed}/{len(pdf_files)}\")\n",
    "    \n",
    "    if successful > 0:\n",
    "        avg_time = sum(r['time'] for r in results if r['status'] == 'success') / successful\n",
    "        total_notes = sum(r['notes'] for r in results if r['status'] == 'success')\n",
    "        print(f\"  ⏱️  Average time: {avg_time:.1f}s\")\n",
    "        print(f\"  🎵 Total notes: {total_notes}\")\n",
    "else:\n",
    "    print(\"⚠️ No files uploaded\")"
   ]
  },
  {
   "cell_type": "markdown",
