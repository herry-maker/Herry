  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "download_module"
   },
   "outputs": [],
   "source": [
    "import os\n",
    "import urllib.request\n",
    "\n",
    "# Create working directory\n",
    "os.makedirs('/content/music_transcription', exist_ok=True)\n",
    "os.chdir('/content/music_transcription')\n",
    "\n",
    "# Download the music_transcriber.py\n",
    "url = 'https://raw.githubusercontent.com/herry-maker/Herry/main/python/music_transcriber.py'\n",
    "urllib.request.urlretrieve(url, 'music_transcriber.py')\n",
    "\n",
    "print(\"✅ Downloaded music_transcriber.py\")\n",
    "print(f\"📁 Working directory: {os.getcwd()}\")\n",
    "print(f\"📄 Files: {os.listdir('.')}\")"
   ]
  },
