    "id": "inspect_details"
   },
   "source": [
    "### Inspect Transcription Details"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "inspect_result"
   },
   "outputs": [],
   "source": [
    "import json\n",
    "from music_transcriber import MusicTranscriber\n",
    "\n",
    "# Get the first PDF to analyze\n",
    "import glob\n",
    "pdf_files = glob.glob('/content/music_transcription/*.pdf')\n",
    "\n",
    "if pdf_files:\n",
    "    pdf_path = pdf_files[0]\n",
    "    output_dir = '/content/music_transcription/analysis'\n",
    "    \n",
    "    import os\n",
    "    os.makedirs(output_dir, exist_ok=True)\n",
    "    \n",
    "    print(f\"📊 Analyzing: {os.path.basename(pdf_path)}\\n\")\n",
    "    \n",
    "    # Create transcriber and process\n",
    "    transcriber = MusicTranscriber(pdf_path, output_dir)\n",
    "    \n",
    "    print(\"Step 1: Converting PDF to images...\")\n",
    "    images = transcriber.convert_pdf_to_images()\n",
    "    print(f\"✅ Converted to {len(images)} pages\\n\")\n",
    "    \n",
    "    print(\"Step 2: Analyzing each page...\")\n",
    "    for page_num, image in enumerate(images, 1):\n",
    "        print(f\"\\n  Page {page_num}:\")\n",
    "        \n",
    "        # Detect staff lines\n",
    "        line_spacing, staff_lines = transcriber.detect_staff_lines(image)\n",
    "        print(f\"    • Staff lines: {len(staff_lines)}\")\n",
    "        print(f\"    • Line spacing: {line_spacing} pixels\")\n",
    "        \n",
    "        # Detect notes\n",
    "        notes = transcriber.detect_notes(image, staff_lines, line_spacing)\n",
    "        print(f\"    • Notes detected: {len(notes)}\")\n",
    "        \n",
    "        if notes:\n",
    "            # Show first 3 notes\n",
    "            print(f\"    • First notes:\")\n",
    "            for note in notes[:3]:\n",
    "                print(f\"      - Pitch: {note['pitch']}, Position: ({note['x']}, {note['y']})\")\n",
    "            if len(notes) > 3:\n",
    "                print(f\"      ... and {len(notes)-3} more\")\n",
    "    \n",
    "    print(f\"\\n\" + \"=\"*50)\n",
    "    print(f\"✅ Analysis complete!\")\n",
    "    print(f\"📊 Total notes across all pages: {len(transcriber.detected_notes)}\")\nelse:\n",
    "    print(\"⚠️ Please upload a PDF first!\")"
   ]
