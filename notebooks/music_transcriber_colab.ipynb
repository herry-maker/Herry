  {
   "cell_type": "markdown",
   "metadata": {
    "id": "run_transcription"
   },
   "source": [
    "## Step 5: Run the Transcription\n",
    "\n",
    "Convert the PDF to MuseScore format!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "transcribe"
   },
   "outputs": [],
   "source": [
    "import json\n",
    "from datetime import datetime\n",
    "\n",
    "# Get the uploaded PDF\n",
    "uploaded = files.upload() if 'uploaded' not in locals() or not uploaded else uploaded\n",
    "pdf_file = list(uploaded.keys())[0] if uploaded else None\n",
    "\n",
    "if not pdf_file:\n",
    "    print(\"⚠️ Please upload a PDF file first!\")\n",
    "else:\n",
    "    pdf_path = f'/content/music_transcription/{pdf_file}'\n",
    "    output_dir = '/content/music_transcription/output'\n",
    "    os.makedirs(output_dir, exist_ok=True)\n",
    "    \n",
    "    # Get title from user (optional)\n",
    "    import ipywidgets as widgets\n",
    "    from IPython.display import display\n",
    "    \n",
    "    # Extract filename without extension as default title\n",
    "    default_title = pdf_file.replace('.pdf', '').replace('_', ' ').title()\n",
    "    \n",
    "    print(f\"\\n🎵 Starting transcription...\")\n",
    "    print(f\"📄 Input: {pdf_file}\")\n",
    "    print(f\"📁 Output: {output_dir}\")\n",
    "    print(f\"⏱️  Time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    \n",
    "    # Run transcription\n",
    "    result = transcribe_pdf_to_musescore(\n",
    "        pdf_path=pdf_path,\n",
    "        output_dir=output_dir,\n",
    "        title=default_title\n",
    "    )\n",
    "    \n",
    "    # Display results\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"\\n📊 TRANSCRIPTION RESULTS:\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    if result['success']:\n",
    "        print(f\"\\n✅ {result['message']}\")\n",
    "        print(f\"\\n📈 Statistics:\")\n",
    "        print(f\"  • Pages processed: {result['pages_processed']}\")\n",
    "        print(f\"  • Notes detected: {result['notes_detected']}\")\n",
    "        print(f\"  • Output file: {os.path.basename(result['output_file'])}\")\n",
    "        print(f\"  • Output size: {os.path.getsize(result['output_file']) / 1024:.2f} KB\")\n",
    "    else:\n",
    "        print(f\"\\n❌ Error: {result['error']}\")\n",
    "        print(f\"\\n💡 Troubleshooting:\")\n",
    "        print(f\"  • Ensure PDF contains sheet music\")\n",
    "        print(f\"  • Try a higher resolution PDF (300+ DPI)\")\n",
    "        print(f\"  • Make sure staff lines are clear\")\n",
    "    \n",
    "    print(\"\\n\" + \"=\"*50)"
   ]
